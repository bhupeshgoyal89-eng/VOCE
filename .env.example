# VOCE Configuration File
# Copy this to .env and fill in your values
# Then load with: source .env (Linux/macOS) or set (Windows)

# Google Gemini API Key (Required for AI obligation extraction)
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Database Configuration (Optional)
# Default: data/voce.db
VOCE_DB_PATH=data/voce.db

# Agreements Directory (Optional)
# Default: agreements/
VOCE_AGREEMENTS_DIR=agreements

# Log Level (Optional)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Streamlit Configuration (Optional)
# Port for the web application
STREAMLIT_SERVER_PORT=8501

# Browser auto-open
STREAMLIT_CLIENT_BROWSER=true
