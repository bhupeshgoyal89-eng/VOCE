# Streamlit Cloud Secrets Configuration
# On Streamlit Cloud, use the Secrets UI at https://share.streamlit.io
# Do NOT commit actual secrets.toml file to git

# Google Gemini API Key - Required for AI obligation extraction
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY = "your-gemini-api-key-here"

# Optional: Database path
DB_PATH = "data/voce.db"
